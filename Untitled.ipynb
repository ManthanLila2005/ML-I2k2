    "arr=list(map(int,input().split()))\n",
    "brr=[0]*len(arr)\n",
    "for i in range(0,len(arr)):\n",
    "    brr[i]=arr[len(arr)-(i+1)]\n",
    "print(*arr)\n",
    "print(*brr)"
